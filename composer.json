{
    "name": "vortexphp/vortex",
    "description": "Lightweight PHP application stack (app/, config/, ui/, lang/)",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "vortexphp/framework": "^0.10",
        "vortexphp/live": "^0.1"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../framework",
            "options": {
                "symlink": true,
                "versions": {
                    "vortexphp/framework": "0.10.0"
                }
            }
        },
        {
            "type": "path",
            "url": "../live",
            "options": {
                "symlink": true,
                "versions": {
                    "vortexphp/live": "0.1.0"
                }
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "suggest": {
        "ext-openssl": "SMTP STARTTLS / ssl:// (MAIL_ENCRYPTION tls or ssl)"
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "sync-live-assets": "@php build/sync-live-assets.php",
        "post-install-cmd": [
            "@sync-live-assets"
        ],
        "post-update-cmd": [
            "@sync-live-assets"
        ],
        "serve": "php vortex serve",
        "doctor": "php vortex doctor",
        "smoke": "php vortex smoke",
        "db-check": "php vortex db-check",
        "migrate": "php vortex migrate",
        "migrate:down": "php vortex migrate:down",
        "install:prod": "@composer install --no-dev --optimize-autoloader",
        "validate-project": "composer validate --no-check-publish",
        "dev": "npm run dev",
        "test": "@php vendor/bin/phpunit -c phpunit.xml.dist",
        "build": [
            "npm run build",
            "@sync-live-assets"
        ],
        "setup": [
            "@composer install",
            "npm install"
        ]
    },
    "bin": [
        "vortex"
    ],
    "require-dev": {
        "phpunit/phpunit": "^11"
    }
}
