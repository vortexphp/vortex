# Install on the server (paths are examples — adjust PROJECT_ROOT):
#   sudo cp docs/deploy/logrotate-app.conf.example /etc/logrotate.d/your-app
#   sudo sed -i '' "s|@PROJECT_ROOT@|/var/www/your-app|g" /etc/logrotate.d/your-app   # macOS sed
#   sudo sed -i "s|@PROJECT_ROOT@|/var/www/your-app|g" /etc/logrotate.d/your-app      # Linux

@PROJECT_ROOT@/storage/logs/*.log {
    weekly
    rotate 8
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
}
