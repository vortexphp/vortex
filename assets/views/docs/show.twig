{% extends 'layouts/default.twig' %}

{% block content %}
<div class="mx-auto max-w-7xl lg:grid lg:grid-cols-[minmax(220px,260px)_1fr] lg:items-start lg:gap-10">
    <aside class="mb-10 lg:sticky lg:top-24 lg:mb-0">
        {% include 'docs/_nav.twig' %}
    </aside>

    <div class="min-w-0">
        <nav class="mb-6 text-sm text-zinc-600 dark:text-zinc-400" aria-label="{{ trans('docs.breadcrumb_nav') }}">
            <ol class="flex flex-wrap items-center gap-1.5">
                {% for crumb in breadcrumbs %}
                    <li class="flex items-center gap-1.5">
                        {% if not loop.first %}
                            <span class="text-zinc-400 dark:text-zinc-600" aria-hidden="true">/</span>
                        {% endif %}
                        {% if crumb.href is not null %}
                            <a href="{{ crumb.href }}" class="rounded-md px-1 py-0.5 transition hover:bg-zinc-100 hover:text-zinc-900 dark:hover:bg-zinc-800 dark:hover:text-white">{{ crumb.label }}</a>
                        {% else %}
                            <span class="font-medium text-zinc-900 dark:text-white">{{ crumb.label }}</span>
                        {% endif %}
                    </li>
                {% endfor %}
            </ol>
        </nav>

        {% if outline|length > 0 %}
            <details class="toc-mobile group mb-8 rounded-2xl border border-zinc-200/80 bg-white/90 px-4 py-3 shadow-sm open:shadow-md dark:border-zinc-800/80 dark:bg-zinc-900/60 xl:hidden">
                <summary class="cursor-pointer list-none text-sm font-semibold text-zinc-900 dark:text-white [&::-webkit-details-marker]:hidden">
                    <span class="flex items-center justify-between gap-2">
                        {{ trans('docs.toc_title') }}
                        <svg class="h-4 w-4 text-zinc-400 transition group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                    </span>
                </summary>
                <ul class="mt-4 max-h-[min(50vh,20rem)] space-y-1 overflow-y-auto border-t border-zinc-200/80 pt-4 dark:border-zinc-800/80">
                    {% for h in outline %}
                        <li class="{{ h.level == 3 ? 'pl-3' : (h.level == 4 ? 'pl-6' : '') }}">
                            <a href="#{{ h.id }}" class="block rounded-md py-1 text-sm text-zinc-600 transition hover:bg-zinc-100 hover:text-emerald-700 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-emerald-400">{{ h.text }}</a>
                        </li>
                    {% endfor %}
                </ul>
            </details>
        {% endif %}

        <div class="xl:grid xl:grid-cols-[minmax(0,42rem)_minmax(11rem,13rem)] xl:items-start xl:gap-10 2xl:gap-14">
            <article id="docs-article" class="docs-markdown prose prose-zinc w-full max-w-none dark:prose-invert prose-headings:scroll-mt-24 prose-a:text-emerald-600 prose-a:no-underline hover:prose-a:underline dark:prose-a:text-emerald-400 prose-blockquote:not-italic prose-blockquote:font-normal prose-blockquote:border-l-[3px] prose-blockquote:border-emerald-500 prose-blockquote:bg-emerald-500/[0.07] prose-blockquote:text-zinc-800 dark:prose-blockquote:border-emerald-400 dark:prose-blockquote:bg-emerald-400/[0.09] dark:prose-blockquote:text-zinc-200 prose-blockquote:rounded-r-lg prose-blockquote:py-2.5 prose-blockquote:px-3.5 prose-blockquote:my-4 [&_pre]:rounded-xl [&_pre]:border [&_pre]:border-zinc-200/90 [&_pre]:bg-zinc-950 [&_pre]:shadow-sm dark:[&_pre]:border-zinc-700/90 [&_pre_code]:font-mono [&_pre_code]:text-[0.8125rem] [&_pre_code]:leading-relaxed dark:[&_pre_code]:text-zinc-100 [&_pre:has(>code.hljs)]:!bg-zinc-950 [&_pre:has(>code.hljs)]:!p-0 [&_pre:has(>code.hljs)]:rounded-xl">
                {{ contentHtml|raw }}
            </article>

            {% if outline|length > 0 %}
                <aside class="sticky top-24 hidden xl:block" aria-label="{{ trans('docs.toc_title') }}">
                    <p class="text-[11px] font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500">{{ trans('docs.toc_title') }}</p>
                    <ul class="mt-3 max-h-[calc(100vh-8rem)] space-y-2 overflow-y-auto border-l border-zinc-200/80 pl-3 dark:border-zinc-800/80">
                        {% for h in outline %}
                            <li class="{{ h.level == 3 ? 'pl-2' : (h.level == 4 ? 'pl-4' : '') }}">
                                <a href="#{{ h.id }}" class="block border-l-2 border-transparent py-0.5 pl-2 text-sm leading-snug text-zinc-600 transition hover:border-emerald-500/60 hover:text-emerald-700 dark:text-zinc-400 dark:hover:text-emerald-400">{{ h.text }}</a>
                            </li>
                        {% endfor %}
                    </ul>
                </aside>
            {% endif %}
        </div>

        {% if prevPage or nextPage %}
            <nav class="not-prose mt-14 flex flex-col gap-3 border-t border-zinc-200/80 pt-10 dark:border-zinc-800/80 sm:flex-row sm:items-stretch sm:justify-between sm:gap-4" aria-label="{{ trans('docs.series_nav') }}">
                {% if prevPage %}
                    <a href="{{ prevPage.href }}" class="group flex flex-1 flex-col rounded-2xl border border-zinc-200/90 bg-white/80 p-4 transition hover:border-emerald-500/35 hover:shadow-md dark:border-zinc-800/90 dark:bg-zinc-900/40 dark:hover:border-emerald-500/25 sm:max-w-md">
                        <span class="text-xs font-medium uppercase tracking-wide text-zinc-400 dark:text-zinc-500">{{ trans('docs.prev_doc') }}</span>
                        <span class="mt-1 font-semibold text-emerald-700 group-hover:text-emerald-600 dark:text-emerald-400 dark:group-hover:text-emerald-300">{{ prevPage.title }}</span>
                    </a>
                {% else %}
                    <span class="hidden flex-1 sm:block"></span>
                {% endif %}
                {% if nextPage %}
                    <a href="{{ nextPage.href }}" class="group flex flex-1 flex-col rounded-2xl border border-zinc-200/90 bg-white/80 p-4 text-right transition hover:border-emerald-500/35 hover:shadow-md dark:border-zinc-800/90 dark:bg-zinc-900/40 dark:hover:border-emerald-500/25 sm:max-w-md sm:ml-auto">
                        <span class="text-xs font-medium uppercase tracking-wide text-zinc-400 dark:text-zinc-500">{{ trans('docs.next_doc') }}</span>
                        <span class="mt-1 font-semibold text-emerald-700 group-hover:text-emerald-600 dark:text-emerald-400 dark:group-hover:text-emerald-300">{{ nextPage.title }}</span>
                    </a>
                {% endif %}
            </nav>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block body_end %}
    {% include 'docs/_scripts.twig' %}
    <script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/highlight.min.js"></script>
    <script>
        if (typeof hljs !== 'undefined') {
            hljs.highlightAll();
        }
    </script>
{% endblock %}
