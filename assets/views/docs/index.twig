{% extends 'layouts/default.twig' %}

{% block content %}
<div class="mx-auto max-w-7xl lg:grid lg:grid-cols-[minmax(220px,260px)_minmax(0,1fr)] lg:items-start lg:gap-10">
    <aside class="mb-10 lg:sticky lg:top-24 lg:mb-0">
        {% if navSections is not empty %}
            {% include 'docs/_nav.twig' %}
        {% endif %}
    </aside>

    <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-3">
            <span class="inline-flex items-center rounded-full bg-amber-500/15 px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wide text-amber-800 ring-1 ring-amber-500/25 dark:bg-amber-500/10 dark:text-amber-200 dark:ring-amber-500/20">{{ trans('docs.index_badge') }}</span>
            {% if hasPages and pageCount is defined %}
                <span class="text-sm text-zinc-500 dark:text-zinc-400">{{ trans('docs.index_pages_count', {'count': pageCount}) }}</span>
            {% endif %}
        </div>

        <h1 class="mt-4 text-3xl font-bold tracking-tight text-zinc-900 dark:text-white sm:text-4xl">{{ trans('docs.index_title') }}</h1>
        <p class="mt-3 max-w-2xl text-base leading-relaxed text-zinc-600 dark:text-zinc-400">{{ trans('docs.index_intro') }}</p>

        {% if not hasPages %}
            <p class="mt-10 text-sm text-zinc-500 dark:text-zinc-500">{{ trans('docs.empty') }}</p>
        {% else %}
            <h2 class="mt-12 text-lg font-semibold text-zinc-900 dark:text-white">{{ trans('docs.index_browse') }}</h2>
            <div class="mt-6 space-y-12">
                {% for section in navSections %}
                    {% if section.items is not empty %}
                        <section aria-labelledby="docs-section-{{ loop.index }}">
                            <h3 id="docs-section-{{ loop.index }}" class="text-xs font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500">{{ section.title }}</h3>
                            <ul class="mt-4 grid gap-3 sm:grid-cols-2">
                                {% for item in section.items %}
                                    <li>
                                        <a href="{{ item.href }}" class="group flex h-full flex-col rounded-2xl border border-zinc-200/90 bg-white/80 p-4 shadow-sm transition hover:border-emerald-500/35 hover:shadow-md dark:border-zinc-800/90 dark:bg-zinc-900/50 dark:hover:border-emerald-500/25">
                                            <span class="font-semibold text-emerald-700 group-hover:text-emerald-600 dark:text-emerald-400 dark:group-hover:text-emerald-300">{{ item.title }}</span>
                                            <span class="mt-2 font-mono text-[11px] leading-snug text-zinc-500 dark:text-zinc-500">{{ item.slug }}.md</span>
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        </section>
                    {% endif %}
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block body_end %}
    {% include 'docs/_scripts.twig' %}
{% endblock %}
