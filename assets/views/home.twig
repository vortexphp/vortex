{% extends 'layouts/default.twig' %}
{% block content %}
<div class="mx-auto max-w-5xl">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-10 lg:items-center">
        <div class="lg:col-span-7">
            <p class="mb-6 inline-flex items-center gap-2 rounded-full border border-emerald-500/25 bg-white/90 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-emerald-800 shadow-sm dark:border-emerald-500/20 dark:bg-emerald-950/50 dark:text-emerald-200">
                <span class="relative flex h-2 w-2">
                    <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
                    <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
                </span>
                {{ trans('home.badge_online') }}
            </p>

            <h1 class="text-balance text-4xl font-semibold tracking-tight text-zinc-900 sm:text-5xl sm:leading-[1.08] lg:text-6xl dark:text-white">
                {{ title }}
            </h1>

            <p class="mt-6 max-w-xl text-pretty text-lg leading-relaxed text-zinc-600 dark:text-zinc-400">
                {{ trans('home.intro') }}
            </p>

            <div class="mt-8 flex flex-wrap gap-2 text-xs font-semibold text-zinc-600 dark:text-zinc-400">
                <span class="rounded-full border border-zinc-200/90 bg-white/80 px-3 py-1 dark:border-zinc-700 dark:bg-zinc-900/60">{{ trans('home.stack_1') }}</span>
                <span class="rounded-full border border-zinc-200/90 bg-white/80 px-3 py-1 dark:border-zinc-700 dark:bg-zinc-900/60">{{ trans('home.stack_2') }}</span>
                <span class="rounded-full border border-zinc-200/90 bg-white/80 px-3 py-1 dark:border-zinc-700 dark:bg-zinc-900/60">{{ trans('home.stack_3') }}</span>
            </div>

            <div class="mt-10 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
                <a href="/blog" class="inline-flex items-center justify-center gap-2 rounded-xl bg-emerald-600 px-6 py-3.5 text-sm font-semibold text-white shadow-lg shadow-emerald-600/25 transition hover:bg-emerald-500 dark:shadow-emerald-950/40">
                    {{ trans('home.blog_cta') }}
                </a>
                <a href="/health" class="inline-flex items-center justify-center gap-2 rounded-xl border border-zinc-300 bg-white px-6 py-3.5 text-sm font-semibold text-zinc-800 shadow-sm transition hover:border-emerald-500/40 hover:text-emerald-700 dark:border-zinc-600 dark:bg-zinc-900/80 dark:text-zinc-100 dark:hover:border-emerald-500/30">
                    <svg class="h-4 w-4 text-emerald-600 dark:text-emerald-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.872l-3.236 4.53L7.53 10.53a.75.75 0 00-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
                    {{ trans('home.health_cta') }}
                </a>
            </div>
            <p class="mt-6 text-sm text-zinc-500 dark:text-zinc-500">
                {{ trans('home.dev_server') }} <code class="rounded-md bg-zinc-200/80 px-2 py-0.5 font-mono text-xs text-zinc-800 dark:bg-zinc-800 dark:text-zinc-200">php vortex serve</code>
            </p>
        </div>

        <div class="lg:col-span-5">
            <div class="relative rounded-3xl border border-zinc-200/90 bg-gradient-to-br from-white to-zinc-50 p-1 shadow-xl shadow-zinc-900/5 dark:border-zinc-700 dark:from-zinc-900 dark:to-zinc-950 dark:shadow-black/40">
                <div class="rounded-[1.35rem] border border-zinc-100 bg-white/90 p-6 dark:border-zinc-800 dark:bg-zinc-950/80 sm:p-8">
                    <p class="text-xs font-semibold uppercase tracking-wider text-emerald-600 dark:text-emerald-400">{{ trans('home.feature_routes') }}</p>
                    <p class="mt-2 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">{{ trans('home.feature_routes_body') }}</p>
                    <div class="my-6 h-px bg-zinc-200 dark:bg-zinc-800"></div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-teal-600 dark:text-teal-400">{{ trans('home.feature_views') }}</p>
                    <p class="mt-2 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">{{ trans('home.feature_views_body') }}</p>
                    <div class="my-6 h-px bg-zinc-200 dark:bg-zinc-800"></div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-cyan-600 dark:text-cyan-400">{{ trans('home.feature_console') }}</p>
                    <p class="mt-2 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
                        <code class="rounded bg-zinc-100 px-1.5 py-0.5 font-mono text-xs text-zinc-800 dark:bg-zinc-800 dark:text-zinc-200">{{ trans('home.feature_console_cmd') }}</code> {{ trans('home.feature_console_tail') }}
                    </p>
                </div>
            </div>
        </div>
    </div>

    <dl class="mt-20 grid gap-5 sm:grid-cols-3">
        <div class="group rounded-2xl border border-zinc-200/90 bg-white/80 p-6 shadow-sm transition hover:border-emerald-500/35 hover:shadow-md dark:border-zinc-800 dark:bg-zinc-900/50 dark:hover:border-emerald-500/30">
            <dt class="flex items-center gap-3 text-sm font-semibold text-zinc-900 dark:text-white">
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-700 dark:text-emerald-300">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
                </span>
                {{ trans('home.feature_routes') }}
            </dt>
            <dd class="mt-3 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">{{ trans('home.feature_routes_body') }}</dd>
        </div>
        <div class="group rounded-2xl border border-zinc-200/90 bg-white/80 p-6 shadow-sm transition hover:border-emerald-500/35 hover:shadow-md dark:border-zinc-800 dark:bg-zinc-900/50 dark:hover:border-emerald-500/30">
            <dt class="flex items-center gap-3 text-sm font-semibold text-zinc-900 dark:text-white">
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-teal-500/10 text-teal-700 dark:text-teal-300">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </span>
                {{ trans('home.feature_views') }}
            </dt>
            <dd class="mt-3 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">{{ trans('home.feature_views_body') }}</dd>
        </div>
        <div class="group rounded-2xl border border-zinc-200/90 bg-white/80 p-6 shadow-sm transition hover:border-emerald-500/35 hover:shadow-md dark:border-zinc-800 dark:bg-zinc-900/50 dark:hover:border-emerald-500/30">
            <dt class="flex items-center gap-3 text-sm font-semibold text-zinc-900 dark:text-white">
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-cyan-500/10 text-cyan-700 dark:text-cyan-300">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z"/></svg>
                </span>
                {{ trans('home.feature_console') }}
            </dt>
            <dd class="mt-3 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
                <code class="rounded bg-zinc-100 px-1.5 py-0.5 font-mono text-xs text-zinc-800 dark:bg-zinc-800 dark:text-zinc-200">{{ trans('home.feature_console_cmd') }}</code> {{ trans('home.feature_console_tail') }}
            </dd>
        </div>
    </dl>

    <p class="mt-16 text-center text-xs text-zinc-400 dark:text-zinc-600">
        {{ trans('home.rebuild_hint') }}
        <code class="rounded-md bg-zinc-200/70 px-2 py-0.5 font-mono text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400">npm run build:css</code>
    </p>
</div>
{% endblock %}
