{% extends 'layouts/default.twig' %}
{% block content %}
{% set isEdit = post is not null %}
{% set action = isEdit ? '/blog/manage/posts/' ~ post.id|default(0) : '/blog/manage/posts' %}
{% set field = 'mt-1.5 block w-full rounded-xl border border-zinc-300 bg-white px-4 py-2.5 text-zinc-900 shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/30 dark:border-zinc-600 dark:bg-zinc-900 dark:text-white' %}
<div class="mx-auto max-w-2xl">
    <h1 class="text-3xl font-semibold tracking-tight text-zinc-900 dark:text-white sm:text-4xl">{{ title }}</h1>
    <p class="mt-3 text-sm text-zinc-600 dark:text-zinc-400">
        <a href="/blog/manage" class="font-semibold text-emerald-600 transition hover:text-emerald-500 dark:text-emerald-400">{{ trans('blog.manage.back') }}</a>
    </p>

    {% if errors['_form'] is defined %}
        <p class="mt-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 dark:border-red-900/50 dark:bg-red-950/40 dark:text-red-200">{{ errors['_form'] }}</p>
    {% endif %}

    <div class="mt-8 rounded-2xl border border-zinc-200/90 bg-white/90 p-6 shadow-lg shadow-zinc-900/5 dark:border-zinc-800 dark:bg-zinc-900/60 dark:shadow-black/20 sm:p-8">
        <form method="post" action="{{ action }}" class="space-y-6">
            <input type="hidden" name="_csrf" value="{{ csrfToken|default('') }}">

            <div>
                <label for="title" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300">{{ trans('blog.manage.fields.title') }}</label>
                <input id="title" name="title" type="text" required value="{{ old.title|default('') }}" class="{{ field }}">
                {% if errors['title'] is defined %}
                    <p class="mt-1 text-sm text-red-600 dark:text-red-400">{{ errors['title'] }}</p>
                {% endif %}
            </div>

            <div>
                <label for="slug" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300">{{ trans('blog.manage.fields.slug') }}</label>
                <input id="slug" name="slug" type="text" value="{{ old.slug|default('') }}" placeholder="{{ trans('blog.manage.fields.slug_placeholder') }}" class="{{ field }} font-mono text-sm">
                {% if errors['slug'] is defined %}
                    <p class="mt-1 text-sm text-red-600 dark:text-red-400">{{ errors['slug'] }}</p>
                {% endif %}
            </div>

            <div>
                <label for="excerpt" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300">{{ trans('blog.manage.fields.excerpt') }}</label>
                <textarea id="excerpt" name="excerpt" rows="2" class="{{ field }}">{{ old.excerpt|default('') }}</textarea>
            </div>

            <div>
                <label for="body" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300">{{ trans('blog.manage.fields.body') }}</label>
                <textarea id="body" name="body" rows="14" required class="{{ field }} font-mono text-sm">{{ old.body|default('') }}</textarea>
                {% if errors['body'] is defined %}
                    <p class="mt-1 text-sm text-red-600 dark:text-red-400">{{ errors['body'] }}</p>
                {% endif %}
            </div>

            <div>
                <label for="published_at" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300">{{ trans('blog.manage.fields.published_at') }}</label>
                <input id="published_at" name="published_at" type="datetime-local" value="{{ old.published_at|default('') }}" class="{{ field }}">
                <p class="mt-1.5 text-xs text-zinc-500 dark:text-zinc-500">{{ trans('blog.manage.fields.published_hint') }}</p>
            </div>

            <button type="submit" class="w-full rounded-xl bg-emerald-600 px-4 py-3.5 text-sm font-semibold text-white shadow-md shadow-emerald-600/20 transition hover:bg-emerald-500 sm:w-auto">
                {{ isEdit ? trans('blog.manage.save') : trans('blog.manage.publish') }}
            </button>
        </form>
    </div>
</div>
{% endblock %}
