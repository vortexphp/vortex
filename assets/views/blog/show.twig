{% extends 'layouts/default.twig' %}
{% block content %}
{% set slug = post.slug|default('') %}
{% set commentStatus = session_flash('comment_status') %}
<div class="mx-auto max-w-3xl">
    <p class="mb-8 text-sm font-medium">
        <a href="/blog" class="inline-flex items-center gap-1 text-emerald-600 transition hover:text-emerald-500 dark:text-emerald-400">{{ trans('blog.back_to_blog') }}</a>
    </p>
    {% set pub = post.published_at|default('') %}
    <article class="rounded-2xl border border-zinc-200/90 bg-white/90 px-6 py-8 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/50 sm:px-10 sm:py-10">
        <time class="text-xs font-semibold uppercase tracking-wide text-zinc-400 dark:text-zinc-500" datetime="{{ pub }}">{{ pub }}</time>
        <h1 class="mt-3 text-balance text-4xl font-semibold tracking-tight text-zinc-900 dark:text-white sm:text-5xl">{{ post.title|default('') }}</h1>
        <div class="prose prose-zinc prose-lg mt-10 max-w-none dark:prose-invert prose-p:leading-relaxed prose-p:text-zinc-700 dark:prose-p:text-zinc-300">
            {% for para in post.body|default('')|paragraphs %}
                <p>{{ para|nl2br_e }}</p>
            {% endfor %}
        </div>
    </article>

    <section class="mt-12 rounded-2xl border border-zinc-200/90 bg-white/60 px-6 py-8 dark:border-zinc-800 dark:bg-zinc-950/40 sm:px-8 sm:py-10" aria-label="{{ trans('blog.comments.heading') }}">
        <h2 class="text-xl font-semibold text-zinc-900 dark:text-white">{{ trans('blog.comments.heading') }}</h2>

        {% if commentStatus is string and commentStatus != '' %}
            <p class="mt-4 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-900 dark:border-emerald-900/40 dark:bg-emerald-950/40 dark:text-emerald-200">{{ commentStatus }}</p>
        {% endif %}
        {% if commentErrors['_form'] is defined %}
            <p class="mt-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 dark:border-red-900/50 dark:bg-red-950/40 dark:text-red-200">{{ commentErrors['_form'] }}</p>
        {% endif %}

        {% if comments is empty %}
            <p class="mt-6 text-sm text-zinc-500 dark:text-zinc-500">{{ trans('blog.comments.empty') }}</p>
        {% else %}
            <ul class="mt-8 space-y-4">
                {% for c in comments %}
                    {% set cname = c.author_name|default('') %}
                    {% set cbody = c.body|default('') %}
                    {% set cat = c.created_at|default('') %}
                    <li class="rounded-xl border border-zinc-200/80 bg-white/90 px-5 py-4 dark:border-zinc-800 dark:bg-zinc-900/60">
                        <p class="text-sm font-semibold text-zinc-900 dark:text-white">{{ cname }}</p>
                        <time class="text-xs text-zinc-400 dark:text-zinc-500" datetime="{{ cat }}">{{ cat }}</time>
                        <div class="mt-2 text-sm leading-relaxed text-zinc-700 dark:text-zinc-300">
                            {% for line in cbody|paragraphs %}
                                <p>{{ line|nl2br_e }}</p>
                            {% endfor %}
                        </div>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}

        <div class="mt-10 border-t border-zinc-200 pt-8 dark:border-zinc-800">
            <h3 class="text-base font-semibold text-zinc-900 dark:text-white">{{ trans('blog.comments.form_heading') }}</h3>
            <form method="post" action="/blog/{{ slug|url_encode }}/comments" class="mt-5 space-y-4">
                <input type="hidden" name="_csrf" value="{{ csrfToken|default('') }}">
                <div>
                    <label for="comment_author_name" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300">{{ trans('blog.comments.name') }}</label>
                    <input id="comment_author_name" name="author_name" type="text" required maxlength="80"
                           value="{{ commentOld.author_name|default('') }}"
                           class="mt-1.5 block w-full rounded-xl border border-zinc-300 bg-white px-4 py-2.5 text-zinc-900 shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/30 dark:border-zinc-600 dark:bg-zinc-900 dark:text-white">
                    {% if commentErrors['author_name'] is defined %}
                        <p class="mt-1 text-sm text-red-600 dark:text-red-400">{{ commentErrors['author_name'] }}</p>
                    {% endif %}
                </div>
                <div>
                    <label for="comment_body" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300">{{ trans('blog.comments.body') }}</label>
                    <textarea id="comment_body" name="body" rows="5" required maxlength="4000"
                              class="mt-1.5 block w-full rounded-xl border border-zinc-300 bg-white px-4 py-2.5 text-zinc-900 shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/30 dark:border-zinc-600 dark:bg-zinc-900 dark:text-white">{{ commentOld.body|default('') }}</textarea>
                    {% if commentErrors['body'] is defined %}
                        <p class="mt-1 text-sm text-red-600 dark:text-red-400">{{ commentErrors['body'] }}</p>
                    {% endif %}
                </div>
                <button type="submit" class="rounded-xl bg-emerald-600 px-5 py-2.5 text-sm font-semibold text-white shadow-md shadow-emerald-600/20 transition hover:bg-emerald-500">
                    {{ trans('blog.comments.submit') }}
                </button>
            </form>
        </div>
    </section>
</div>
{% endblock %}
