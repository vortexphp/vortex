{% extends 'layouts/default.twig' %}
{% block content %}
<div class="mx-auto max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-wider text-emerald-600 dark:text-emerald-400">{{ trans('blog.eyebrow') }}</p>
    <h1 class="mt-2 text-4xl font-semibold tracking-tight text-zinc-900 dark:text-white sm:text-5xl">{{ title }}</h1>
    <p class="mt-4 text-lg text-zinc-600 dark:text-zinc-400">{{ trans('blog.tagline') }}</p>

    {% if authUser is not null %}
        <p class="mt-8">
            <a href="/blog/manage" class="inline-flex items-center gap-2 rounded-lg border border-emerald-200 bg-emerald-50/80 px-4 py-2 text-sm font-semibold text-emerald-900 transition hover:bg-emerald-100 dark:border-emerald-900/40 dark:bg-emerald-950/40 dark:text-emerald-200 dark:hover:bg-emerald-900/30">{{ trans('blog.manage.link') }}</a>
        </p>
    {% endif %}

    {% if posts is empty %}
        <div class="mt-16 rounded-2xl border border-dashed border-zinc-300 bg-zinc-50/80 px-6 py-16 text-center dark:border-zinc-700 dark:bg-zinc-900/40">
            <p class="text-zinc-600 dark:text-zinc-400">{{ trans('blog.empty') }}</p>
        </div>
    {% else %}
        <ul class="mt-14 space-y-6">
            {% for post in posts %}
                {% set slug = post.slug|default('') %}
                {% set ptitle = post.title|default('') %}
                {% set rawEx = post.excerpt|default('') %}
                {% set ex = rawEx != '' ? rawEx : (post.body|default('')|excerpt_html(180)) %}
                {% set pub = post.published_at|default('') %}
                <li class="group rounded-2xl border border-zinc-200/90 bg-white/90 p-6 shadow-sm transition hover:border-emerald-500/30 hover:shadow-md dark:border-zinc-800 dark:bg-zinc-900/60 dark:hover:border-emerald-500/25 sm:p-8">
                    <time class="text-xs font-semibold uppercase tracking-wide text-zinc-400 dark:text-zinc-500" datetime="{{ pub }}">{{ pub }}</time>
                    <h2 class="mt-3 text-2xl font-semibold text-zinc-900 dark:text-white">
                        <a href="/blog/{{ slug|url_encode }}" class="transition hover:text-emerald-600 dark:hover:text-emerald-400">{{ ptitle }}</a>
                    </h2>
                    <p class="mt-3 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">{{ ex }}</p>
                    <a href="/blog/{{ slug|url_encode }}" class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-emerald-600 transition group-hover:gap-2 dark:text-emerald-400">{{ trans('blog.read_more') }} <span aria-hidden="true">→</span></a>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</div>
{% endblock %}
