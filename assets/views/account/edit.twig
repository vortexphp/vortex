{% extends 'layouts/default.twig' %}
{% block content %}
{% set currentAvatar = authUser is not null and authUser.avatar|default('') != '' ? authUser.avatar : null %}
{% set field = 'mt-1.5 block w-full rounded-xl border border-zinc-300 bg-white px-4 py-2.5 text-zinc-900 shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/30 dark:border-zinc-600 dark:bg-zinc-900 dark:text-white' %}
<div class="mx-auto max-w-md">
    <h1 class="text-3xl font-semibold tracking-tight text-zinc-900 dark:text-white">{{ title }}</h1>
    <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
        <a href="/account" class="font-semibold text-emerald-600 transition hover:text-emerald-500 dark:text-emerald-400">{{ trans('account.edit.back') }}</a>
    </p>

    {% if errors['_form'] is defined %}
        <p class="mt-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 dark:border-red-900/50 dark:bg-red-950/40 dark:text-red-200">{{ errors['_form'] }}</p>
    {% endif %}

    <div class="mt-8 rounded-2xl border border-zinc-200/90 bg-white/90 p-6 shadow-xl shadow-zinc-900/5 dark:border-zinc-800 dark:bg-zinc-900/70 dark:shadow-black/30 sm:p-8">
        <form method="post" action="/account/edit" enctype="multipart/form-data" class="space-y-6">
            <input type="hidden" name="_csrf" value="{{ csrfToken|default('') }}">

            <div>
                <label for="name" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300">{{ trans('account.edit.name') }}</label>
                <input id="name" name="name" type="text" autocomplete="name" required value="{{ old.name|default('') }}" class="{{ field }}">
                {% if errors['name'] is defined %}
                    <p class="mt-1 text-sm text-red-600 dark:text-red-400">{{ errors['name'] }}</p>
                {% endif %}
            </div>

            <div>
                <label for="email" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300">{{ trans('account.edit.email') }}</label>
                <input id="email" name="email" type="email" autocomplete="email" required value="{{ old.email|default('') }}" class="{{ field }}">
                {% if errors['email'] is defined %}
                    <p class="mt-1 text-sm text-red-600 dark:text-red-400">{{ errors['email'] }}</p>
                {% endif %}
            </div>

            <div>
                <p class="block text-sm font-medium text-zinc-700 dark:text-zinc-300">{{ trans('account.edit.photo') }}</p>
                <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-500">{{ trans('account.edit.photo_hint') }}</p>
                {% if currentAvatar is not null %}
                    <div class="mt-4 flex flex-wrap items-start gap-4">
                        <div>
                            <p class="text-xs text-zinc-500 dark:text-zinc-500">{{ trans('account.edit.photo_current') }}</p>
                            <img src="{{ public_url(currentAvatar) }}" alt="" class="mt-1 h-24 w-24 rounded-xl object-cover shadow-sm ring-1 ring-zinc-200 dark:ring-zinc-700" width="96" height="96">
                        </div>
                        <label class="mt-2 flex cursor-pointer items-center gap-2 text-sm text-zinc-600 dark:text-zinc-400 sm:mt-8">
                            <input type="checkbox" name="remove_avatar" value="1" class="rounded border-zinc-300 text-emerald-600 focus:ring-emerald-500 dark:border-zinc-600">
                            {{ trans('account.edit.remove_photo') }}
                        </label>
                    </div>
                {% endif %}
                <input type="file" name="avatar" accept="image/jpeg,image/png,image/webp" class="mt-3 block w-full text-sm text-zinc-600 file:mr-4 file:rounded-xl file:border-0 file:bg-emerald-50 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-emerald-800 hover:file:bg-emerald-100 dark:text-zinc-400 dark:file:bg-emerald-950/50 dark:file:text-emerald-200 dark:hover:file:bg-emerald-900/40">
                {% if errors['avatar'] is defined %}
                    <p class="mt-1 text-sm text-red-600 dark:text-red-400">{{ errors['avatar'] }}</p>
                {% endif %}
            </div>

            <div class="border-t border-zinc-200 pt-6 dark:border-zinc-800">
                <p class="text-sm text-zinc-600 dark:text-zinc-400">{{ trans('account.edit.password_hint') }}</p>
                <div class="mt-4 space-y-5">
                    <div>
                        <label for="password" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300">{{ trans('account.edit.new_password') }}</label>
                        <input id="password" name="password" type="password" autocomplete="new-password" minlength="8" class="{{ field }}">
                        {% if errors['password'] is defined %}
                            <p class="mt-1 text-sm text-red-600 dark:text-red-400">{{ errors['password'] }}</p>
                        {% endif %}
                    </div>
                    <div>
                        <label for="password_confirmation" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300">{{ trans('account.edit.new_password_confirmation') }}</label>
                        <input id="password_confirmation" name="password_confirmation" type="password" autocomplete="new-password" minlength="8" class="{{ field }}">
                        {% if errors['password_confirmation'] is defined %}
                            <p class="mt-1 text-sm text-red-600 dark:text-red-400">{{ errors['password_confirmation'] }}</p>
                        {% endif %}
                    </div>
                </div>
            </div>

            <button type="submit" class="w-full rounded-xl bg-emerald-600 px-4 py-3.5 text-sm font-semibold text-white shadow-lg shadow-emerald-600/25 transition hover:bg-emerald-500 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 dark:shadow-emerald-950/40">
                {{ trans('account.edit.submit') }}
            </button>
        </form>
    </div>
</div>
{% endblock %}
