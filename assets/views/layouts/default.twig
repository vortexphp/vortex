<!DOCTYPE html>
<html lang="{{ htmlLang|default('en') }}" class="h-full">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if title is defined and title != '' %}{{ title }} · {{ appName|default('App') }}{% else %}{{ appName|default('App') }}{% endif %}</title>
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#09090b" media="(prefers-color-scheme: dark)">
    {% if metaDescription is defined and metaDescription != '' %}
        <meta name="description" content="{{ metaDescription }}">
    {% endif %}
    <link rel="stylesheet" href="/css/app.css">
    {% block head_extra %}{% endblock %}
</head>
<body class="min-h-full bg-zinc-50 font-sans text-zinc-900 antialiased dark:bg-zinc-950 dark:text-zinc-100">
<div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden" aria-hidden="true">
    <div class="absolute -top-40 left-1/2 h-[min(480px,50vh)] w-[min(960px,100vw)] -translate-x-1/2 rounded-full bg-emerald-400/18 blur-3xl dark:bg-emerald-950/50"></div>
    <div class="absolute top-1/4 -right-24 h-64 w-64 rounded-full bg-teal-400/14 blur-3xl dark:bg-teal-950/35"></div>
</div>

<div class="flex min-h-full flex-col">
    <header class="sticky top-0 z-50 border-b border-zinc-200/80 bg-white/80 backdrop-blur-xl dark:border-zinc-800/80 dark:bg-zinc-950/80">
        <div class="px-4 sm:px-6 lg:px-8">
            <div class="mx-auto flex h-16 max-w-5xl items-center justify-between gap-3">
            <a href="/" class="group flex min-w-0 items-center gap-2.5 text-zinc-900 dark:text-white">
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-emerald-500 to-teal-600 shadow-lg shadow-emerald-600/20 ring-1 ring-emerald-500/25 dark:shadow-emerald-950/50" aria-hidden="true">
                    <svg class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                </span>
                <span class="hidden min-w-0 flex-col leading-tight sm:flex">
                    <span class="truncate text-sm font-semibold tracking-tight">{{ appName|default('App') }}</span>
                    <span class="truncate text-[11px] font-medium text-zinc-500 dark:text-zinc-400">{{ trans('layout.tagline_short') }}</span>
                </span>
            </a>

            <div class="flex shrink-0 flex-wrap items-center justify-end gap-1 sm:gap-2">
                <nav class="flex flex-wrap items-center gap-0.5 text-sm font-medium sm:gap-1" aria-label="{{ trans('layout.nav_label') }}">
                    <a href="/" class="rounded-lg px-2.5 py-2 text-zinc-600 transition hover:bg-zinc-100 hover:text-zinc-900 sm:px-3 dark:text-zinc-400 dark:hover:bg-zinc-800/80 dark:hover:text-white">{{ trans('nav.home') }}</a>
                </nav>
                {% if supportedLocales is iterable and supportedLocales|length > 0 %}
                    <div class="ml-1 flex items-center gap-0.5 rounded-lg border border-zinc-200/90 bg-white/70 p-0.5 text-[11px] font-medium dark:border-zinc-700 dark:bg-zinc-900/50">
                        {% for code in supportedLocales %}
                            {% if code is string and code != '' %}
                                <a href="?lang={{ code }}" class="rounded-md px-2 py-1 {{ (locale|default('')) == code ? 'bg-emerald-600 text-white shadow-sm' : 'text-zinc-500 hover:bg-zinc-100 hover:text-zinc-800 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-200' }}" hreflang="{{ code }}">{{ trans('locale.native.' ~ code) }}</a>
                            {% endif %}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
            </div>
        </div>
    </header>

    <main id="main" class="flex-1 px-4 py-10 sm:px-6 sm:py-12 lg:px-8 lg:py-14">
        {% block content %}{% endblock %}
    </main>

    <footer class="mt-auto border-t border-zinc-200/80 bg-white/50 dark:border-zinc-800/80 dark:bg-zinc-950/50">
        <div class="px-4 sm:px-6 lg:px-8">
            <div class="mx-auto max-w-5xl py-12">
            <div class="flex flex-col gap-10 sm:flex-row sm:items-start sm:justify-between">
                <div class="max-w-md">
                    <p class="flex items-center gap-2.5 text-sm font-semibold text-zinc-900 dark:text-white">
                        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-emerald-500 to-teal-600 text-white shadow-md" aria-hidden="true">
                            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                        </span>
                        {{ appName|default('App') }}
                    </p>
                    <p class="mt-3 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">{{ trans('layout.footer_about') }}</p>
                </div>
                <div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500">{{ trans('layout.footer_explore') }}</p>
                    <ul class="mt-3 space-y-2.5 text-sm">
                        <li><a href="/" class="text-zinc-600 transition hover:text-emerald-600 dark:text-zinc-400 dark:hover:text-emerald-400">{{ trans('nav.home') }}</a></li>
                    </ul>
                </div>
            </div>
            <div class="mt-10 flex flex-col gap-2 border-t border-zinc-200/80 pt-8 text-xs text-zinc-500 dark:border-zinc-800 dark:text-zinc-500 sm:flex-row sm:items-center sm:justify-between">
                <p>© {{ 'now'|date('Y') }} {{ appName|default('App') }}. {{ trans('layout.footer_rights') }}</p>
                <p class="flex flex-wrap items-center gap-2 text-zinc-400 dark:text-zinc-600 sm:justify-end">
                    <span>{{ trans('layout.footer_stack') }}</span>
                    <span aria-hidden="true">•</span>
                    <span class="tabular-nums">{{ trans('layout.footer_render_time') }} {{ renderTimeMs|default(0) }} ms</span>
                </p>
            </div>
            </div>
        </div>
    </footer>
</div>
{% block body_end %}{% endblock %}
</body>
</html>
