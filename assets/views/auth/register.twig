{% extends 'layouts/default.twig' %}
{% block content %}
{% set field = 'mt-1.5 block w-full rounded-xl border border-zinc-300 bg-white px-4 py-2.5 text-zinc-900 shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/30 dark:border-zinc-600 dark:bg-zinc-900 dark:text-white' %}
<div class="mx-auto max-w-md">
    <div class="rounded-2xl border border-zinc-200/90 bg-white/90 p-8 shadow-xl shadow-zinc-900/5 dark:border-zinc-800 dark:bg-zinc-900/70 dark:shadow-black/30 sm:p-10">
        <h1 class="text-3xl font-semibold tracking-tight text-zinc-900 dark:text-white">{{ title }}</h1>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">{{ trans('auth.register.already') }} <a class="font-semibold text-emerald-600 transition hover:text-emerald-500 dark:text-emerald-400" href="/login">{{ trans('auth.register.sign_in_link') }}</a></p>

        {% if errors['_form'] is defined %}
            <p class="mt-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 dark:border-red-900/50 dark:bg-red-950/40 dark:text-red-200">{{ errors['_form'] }}</p>
        {% endif %}

        <form method="post" action="/register" class="mt-8 space-y-5">
            <input type="hidden" name="_csrf" value="{{ csrfToken|default('') }}">

            <div>
                <label for="name" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300">{{ trans('auth.register.name') }}</label>
                <input id="name" name="name" type="text" autocomplete="name" required value="{{ old.name|default('') }}" class="{{ field }}">
                {% if errors['name'] is defined %}
                    <p class="mt-1 text-sm text-red-600 dark:text-red-400">{{ errors['name'] }}</p>
                {% endif %}
            </div>

            <div>
                <label for="email" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300">{{ trans('auth.register.email') }}</label>
                <input id="email" name="email" type="email" autocomplete="email" required value="{{ old.email|default('') }}" class="{{ field }}">
                {% if errors['email'] is defined %}
                    <p class="mt-1 text-sm text-red-600 dark:text-red-400">{{ errors['email'] }}</p>
                {% endif %}
            </div>

            <div>
                <label for="password" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300">{{ trans('auth.register.password') }}</label>
                <input id="password" name="password" type="password" autocomplete="new-password" required minlength="8" class="{{ field }}">
                {% if errors['password'] is defined %}
                    <p class="mt-1 text-sm text-red-600 dark:text-red-400">{{ errors['password'] }}</p>
                {% endif %}
            </div>

            <div>
                <label for="password_confirmation" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300">{{ trans('auth.register.password_confirmation') }}</label>
                <input id="password_confirmation" name="password_confirmation" type="password" autocomplete="new-password" required minlength="8" class="{{ field }}">
                {% if errors['password_confirmation'] is defined %}
                    <p class="mt-1 text-sm text-red-600 dark:text-red-400">{{ errors['password_confirmation'] }}</p>
                {% endif %}
            </div>

            <button type="submit" class="w-full rounded-xl bg-emerald-600 px-4 py-3.5 text-sm font-semibold text-white shadow-lg shadow-emerald-600/25 transition hover:bg-emerald-500 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 dark:shadow-emerald-950/40">
                {{ trans('auth.register.submit') }}
            </button>
        </form>
    </div>
</div>
{% endblock %}
