<!DOCTYPE html>
<html lang="{{ htmlLang|default('en') }}" class="h-full">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="/css/app.css">
</head>
<body class="min-h-full bg-zinc-50 font-sans text-zinc-900 antialiased dark:bg-zinc-950 dark:text-zinc-100">
<div class="mx-auto max-w-2xl px-6 py-16 sm:py-24">
    <div class="rounded-2xl border border-zinc-200/90 bg-white/90 p-8 shadow-xl shadow-zinc-900/5 dark:border-zinc-800 dark:bg-zinc-900/70 dark:shadow-black/30 sm:p-10">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-red-600 dark:text-red-400">500</p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-zinc-900 dark:text-white sm:text-4xl">{{ title }}</h1>
        <p class="mt-4 text-lg text-zinc-600 dark:text-zinc-400">{{ message }}</p>
        {% if trace is defined and trace is not null and trace != '' %}
            <pre class="mt-8 max-h-80 overflow-auto rounded-xl border border-zinc-200 bg-zinc-950 p-4 text-left text-xs leading-relaxed text-zinc-200 dark:border-zinc-700">{{ trace }}</pre>
        {% endif %}
        <a href="/" class="mt-10 inline-flex rounded-xl bg-zinc-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-zinc-800 dark:bg-white dark:text-zinc-900 dark:hover:bg-zinc-200">{{ trans('errors.500.back') }}</a>
    </div>
</div>
</body>
</html>
